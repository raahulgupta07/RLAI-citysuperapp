# ===========================================
# City GPT SuperApp — Environment Variables
# ===========================================

# LDAP Configuration (optional)
LDAP_URL=
LDAP_BIND_DN=uid={username},ou=users,dc=example,dc=com
LDAP_SEARCH_BASE=ou=users,dc=example,dc=com

# Keycloak SSO (optional)
KEYCLOAK_URL=
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# JWT Secret (change in production!)
JWT_SECRET=superapp-secret-change-me-in-prod

# Super Admin credentials (for local login)
SUPER_ADMIN_USER=admin
SUPER_ADMIN_PASS=admin

# Database path
DB_PATH=./frontend/data/superapp.db

# Node environment
NODE_ENV=development
